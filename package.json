{
  "name": "clhoria-template",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "start": "dotenvx run -- node dist/index.js",
    "typecheck": "pnpm exec tsgo --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest",
    "build": "vite build",
    "generate": "npx drizzle-kit generate --config drizzle.config.ts",
    "push": "npx drizzle-kit push",
    "studio": "npx drizzle-kit studio --config drizzle.config.ts",
    "seed": "npx tsx migrations/seed/index.ts",
    "migrate": "npx drizzle-kit migrate",
    "db:comments": "npx tsx scripts/sync-comments.ts",
    "db:comments:dry": "npx tsx scripts/sync-comments.ts --dry-run",
    "db:migrate": "npx drizzle-kit migrate && npx tsx scripts/sync-comments.ts",
    "db:push": "npx drizzle-kit push && npx tsx scripts/sync-comments.ts",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/s3-request-presigner": "^3.1028.0",
    "@cap.js/server": "^4.0.5",
    "@casbin/redis-watcher": "^1.2.0",
    "@dotenvx/dotenvx": "^1.61.0",
    "@hono/node-server": "^1.19.13",
    "@hono/node-ws": "^1.3.0",
    "@hono/sentry": "^1.2.2",
    "@hono/zod-openapi": "^1.2.4",
    "@node-rs/argon2": "^2.0.2",
    "@scalar/hono-api-reference": "^0.10.7",
    "bullmq": "^5.73.3",
    "casbin": "^5.49.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "1.0.0-beta.21",
    "effect": "^3.21.0",
    "excelize-wasm": "^0.1.2",
    "hono": "^4.12.12",
    "hono-pino": "^0.10.3",
    "hono-rate-limiter": "^0.5.3",
    "iconv-lite": "^0.7.2",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "rate-limit-redis": "^4.3.1",
    "redlock-universal": "^0.8.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.1.1",
    "@bull-board/api": "^6.21.0",
    "@bull-board/hono": "^6.21.0",
    "@bull-board/ui": "^6.21.0",
    "@clhoria/vite-plugin": "workspace:*",
    "@fission-ai/openspec": "^1.2.0",
    "@hono/vite-dev-server": "^0.25.1",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260410.1",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "1.0.0-beta.21",
    "eslint": "^10.2.0",
    "eslint-plugin-format": "^2.0.1",
    "glob": "^13.0.6",
    "nano-staged": "^1.0.2",
    "oxc-parser": "^0.124.0",
    "pino-pretty": "^13.1.3",
    "simple-git-hooks": "^2.13.1",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "bash -c 'pnpm typecheck'"
    ]
  }
}
